  },
  "response": {
    "format": "JSON",
    "fields": {
      "data.code": "证券代码",
      "data.name": "证券简称",
      "data.close": "昨收",
      "data.open": "开盘",
      "data.now": "最新价",
      "data.high": "最高",
      "data.low": "最低",
      "data.volume": "成交量(股)",
      "data.amount": "成交金额(元)",
      "data.delta": "涨跌额",
      "data.deltaPercent": "涨跌幅(%)",
      "data.sellbuy5": "五档盘口 [{price, volume}, ...]（卖5-卖1, 买1-买5 共10档）",
      "data.picupdata": "分时走势数据 [[时间,价格,均价,成交量], ...]",
      "datetime": "数据时间"
    }
  },
  "example": "curl -sk 'https://www.szse.cn/api/market/ssjjhq/getTimeData?marketId=1&code=000001'",
  "auth": "none",
  "confidence": 0.97,
