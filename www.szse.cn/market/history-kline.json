{
  "domain": "www.szse.cn",
  "page_url": "https://www.szse.cn/market/trend/index.html",
  "title": "深交所个股历史K线",
  "description": "获取深市任意股票的历史K线数据（日K/周K/月K），含 OHLCV 和涨跌幅。日K约201条（~10个月），周K约201条（~4年），月K约201条（~17年）。无需认证。",
  "endpoint": "https://www.szse.cn/api/market/ssjjhq/getHistoryData",
  "method": "GET",
  "params": {
    "marketId": { "value": "1", "required": true, "description": "市场ID，1=深市" },
    "code": { "example": "000001", "required": true, "description": "6位证券代码" },
    "cycleType": { "required": true, "description": "K线周期：32=日K, 33=周K, 34=月K" }
  },
  "response": {
    "format": "JSON",
    "fields": {
      "data.code": "证券代码",
      "data.name": "证券简称",
      "data.picupdata": "K线数组，每条: [日期, 开盘, 收盘, 最低, 最高, 涨跌额, 涨跌幅%, 成交量(股), 成交额(元)]"
    }
  },
  "example": "curl -sk 'https://www.szse.cn/api/market/ssjjhq/getHistoryData?marketId=1&code=000001&cycleType=32'",
  "auth": "none",
  "confidence": 0.97,
  "last_verified": "2026-03-18",
  "notes": "固定返回最近201条记录，无法指定日期范围。日K覆盖约10个月，月K可追溯到2009年。"
}